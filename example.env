# Server Configuration
PORT=5252
DEBUG=False

# Logging
# DEBUG_LOCAL=true → human-readable console logs (local dev)
# DEBUG_LOCAL=false → structured JSON shipped to Loki (production); requires LOKI_* below
DEBUG_LOCAL=true
LOG_LEVEL=INFO

# Loki (only required when DEBUG_LOCAL=false)
LOKI_ENDPOINT=https://loki.example.com/loki/api/v1/push
LOKI_USER=your_loki_user
LOKI_PASSWORD=your_loki_password
# Path inside the container; mount your CA via docker-compose volume.
# Set to "false" (string) to disable SSL verification.
LOKI_CA_BUNDLE_PATH=/app/certs/loki-ca.pem

# Database Configuration
BYTEFORGE_CONVERSE_DB_HOST=localhost
BYTEFORGE_CONVERSE_DB_PORT=5432
BYTEFORGE_CONVERSE_DB_NAME=byteforge_converse
BYTEFORGE_CONVERSE_DB_USER=byteforge_converse
BYTEFORGE_CONVERSE_DB_PASSWORD=your_password_here

# CORS — comma-separated list of allowed origins for the frontend(s) that
# embed the chat UI
ALLOWED_ORIGINS=http://localhost:3000

# LLM proxy (OpenRouter via openrouter-client-unofficial)
BYTEFORGE_CONVERSE_OPENROUTER_API_KEY=your_openrouter_api_key
# Default model when a conversation does not pin its own (overridable per-conversation)
BYTEFORGE_CONVERSE_LLM_MODEL=anthropic/claude-3.5-sonnet
